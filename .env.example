# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Channel to publish posts into (e.g. @mychannel or -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel_here

# Your personal Telegram user ID (for admin bot commands)
ADMIN_TELEGRAM_ID=123456789

# Telethon — for reading Telegram channels as sources
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Deepseek API key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Target language for posts (e.g. ru, en, uk)
TARGET_LANGUAGE=ru
